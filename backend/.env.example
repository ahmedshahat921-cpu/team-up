# ============================================
# TeamUp Backend - Environment Variables
# Copy this to .env and fill in your values
# ============================================

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

# Supabase (get from https://supabase.com → Project Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...YOUR_SERVICE_ROLE_KEY

# JWT Secret (use any random string)
JWT_SECRET=teamup-secret-key-change-this-in-production

# Google Gemini API Key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Jitsi Meet (free, no key needed)
JITSI_DOMAIN=meet.jit.si
